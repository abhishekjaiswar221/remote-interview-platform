# Configs and Secrets

# Environment: dev, prod
ENVIRONMENT=dev

# Application Port
PORT=5000

# Database URL
MONGO_DB_URI=mongodb://localhost:27017/DB_NAME

# CLERK PUBLISHABLE KEY
CLERK_PUBLISHABLE_KEY=

# CLERK SECRET KEY
CLERK_SECRET_KEY=

# CLIENT URL -> For multiple client url's use comma and separate the url's
CLIENT_URL=http://localhost:3000,http://localhost:5000

# INNGEST EVENT KEY
INNGEST_EVENT_KEY=

# INNGEST SIGNING KEY
INNGEST_SIGNING_KEY=

# STREAM API KEY
STREAM_API_KEY=

# STREAM API SECRET
STREAM_API_SECRET=