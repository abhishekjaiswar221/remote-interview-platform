{
  "name": "remote-interview-platform",
  "version": "1.0.0",
  "description": "Video calling remote interview platform",
  "homepage": "https://github.com/abhishekjaiswar221/remote-interview-platform#readme",
  "bugs": {
    "url": "https://github.com/abhishekjaiswar221/remote-interview-platform/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhishekjaiswar221/remote-interview-platform.git"
  },
  "license": "MIT",
  "author": "Abhishek Jaiswar",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start:frontend": "cd frontend && npm run dev",
    "start:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "build": "npm install --omit=dev --prefix backend && npm install --omit=dev --prefix frontend && npm run build --prefix frontend",
    "start": "npm run start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
